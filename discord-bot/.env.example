# Bot Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# Roblox Configuration
ROBLOX_USER_ID=123456
ROBLOX_GROUP_ID=123456

# Channel IDs
LOG_CHANNEL_ID=1234567890
AID_REQUEST_CHANNEL_ID=1234567890
INACTIVITY_CHANNEL_ID=1234567890
DISCHARGE_REQUEST_CHANNEL_ID=1234567890
DISCHARGE_LOG_CHANNEL_ID=1234567890
EVENT_LOG_CHANNEL_ID=1481025784012603453

# Role IDs
INACTIVITY_ROLE_ID=1234567890
INACTIVITY_COOLDOWN_ROLE_ID=1234567890
DISCHARGE_PING_ROLE_ID=1234567890
DISCHARGE_LOG_PING_ROLE_ID=1234567890

# EP System — Role & Permissions
# Users with this role (or any role ranked higher) can use /ep edit
EP_MANAGER_ROLE_ID=1234567890
# Role required for /log (falls back to EP_MANAGER_ROLE_ID if not set)
LOG_ROLE_ID=1234567890
# Role required for /gen-report (falls back to EP_MANAGER_ROLE_ID if not set)
REPORT_ROLE_ID=1234567890

# EP System — Sync interval (hours between automatic Roblox group member syncs)
EP_SYNC_INTERVAL_HOURS=6


# Backup System
# Channel that receives "Bot Online" / "Bot Offline" status embeds
STATUS_CHANNEL_ID=1234567890
# Comma-separated list of channel IDs to hide while bot is online
# and unhide automatically when the bot goes offline
BACKUP_CHANNEL_IDS=1234567890,0987654321

# Anthropic API (used as OCR fallback in /log)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model used for screenshot username extraction (defaults to claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Bot Settings
FOOTER_TEXT= NAME HERE | developed by: ljs4426
EMBED_COLOR=0xFFFF00
MAX_INACTIVITY_DAYS=30
TEST_MODE=false

# REST API
# Secret key — include as "X-API-Key: <value>" header on every request
API_KEY=change_me_to_a_strong_secret
# Host and port the API listens on (put nginx/Cloudflare in front for HTTPS)
API_HOST=0.0.0.0
API_PORT=8080

# Report settings
REPORT_UNIT_NAME=NAME HERE
REPORT_TOP_EP_COUNT=10
# Channel where the auto-report is posted every Sunday at 19:00 UTC
REPORT_CHANNEL_ID=1234567890
# Optional DOCX colour overrides (6-char hex, no #)
REPORT_COLOR_PRIMARY=1B2A4A
REPORT_COLOR_ACCENT=C9A84C

# Google Sheets EP sync (optional)
# Set ENABLE_SHEETS=true and provide a service account JSON + sheet ID
ENABLE_SHEETS=false
GOOGLE_SHEETS_CREDS_FILE=
GOOGLE_SHEET_ID=your_google_sheet_id_here
# How often to sync (hours); defaults to EP_SYNC_INTERVAL_HOURS if not set
SHEETS_SYNC_INTERVAL_HOURS=6

# Command / Feature Toggle (true/false)
ENABLE_REQUEST_AID=true
ENABLE_INACTIVITY=true
ENABLE_DISCHARGE=true
ENABLE_EP=true
ENABLE_LOG=true
ENABLE_BACKUP=true
ENABLE_API=true
ENABLE_REPORT=true
